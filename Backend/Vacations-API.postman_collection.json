{
  "info": {
    "name": "Vacations Management System API",
    "description": "REST API for the Vacations Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"test123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["var json = pm.response.json();", "if (json.token) { pm.collectionVariables.set('token', json.token); }"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@vacations.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{baseUrl}}/api/auth/me"
          }
        }
      ]
    },
    {
      "name": "Vacations",
      "item": [
        {
          "name": "Get Vacations",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/vacations?page=1&filter=all",
              "host": ["{{baseUrl}}"],
              "path": ["api", "vacations"],
              "query": [
                {"key": "page", "value": "1"},
                {"key": "filter", "value": "all"}
              ]
            }
          }
        },
        {
          "name": "Get Vacation by ID",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{baseUrl}}/api/vacations/1"
          }
        },
        {
          "name": "Toggle Like",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{baseUrl}}/api/vacations/1/like"
          }
        },
        {
          "name": "Create Vacation",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "body": {
              "mode": "formdata",
              "formdata": [
                {"key": "destination", "value": "Berlin, Germany", "type": "text"},
                {"key": "description", "value": "Explore Berlin history and culture", "type": "text"},
                {"key": "startDate", "value": "2026-09-15", "type": "text"},
                {"key": "endDate", "value": "2026-09-25", "type": "text"},
                {"key": "price", "value": "1999", "type": "text"},
                {"key": "image", "type": "file", "src": ""}
              ]
            },
            "url": "{{baseUrl}}/api/vacations"
          }
        },
        {
          "name": "Update Vacation",
          "request": {
            "method": "PUT",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "body": {
              "mode": "formdata",
              "formdata": [
                {"key": "destination", "value": "Berlin, Germany", "type": "text"},
                {"key": "description", "value": "Updated description", "type": "text"},
                {"key": "startDate", "value": "2026-09-15", "type": "text"},
                {"key": "endDate", "value": "2026-09-25", "type": "text"},
                {"key": "price", "value": "2199", "type": "text"}
              ]
            },
            "url": "{{baseUrl}}/api/vacations/1"
          }
        },
        {
          "name": "Delete Vacation",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{baseUrl}}/api/vacations/1"
          }
        },
        {
          "name": "Get Report",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{baseUrl}}/api/vacations/report"
          }
        },
        {
          "name": "Download CSV",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{baseUrl}}/api/vacations/report/csv"
          }
        }
      ]
    },
    {
      "name": "AI",
      "item": [
        {
          "name": "Get Recommendation",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destination\": \"Paris, France\"\n}"
            },
            "url": "{{baseUrl}}/api/ai/recommend"
          }
        }
      ]
    },
    {
      "name": "MCP",
      "item": [
        {
          "name": "Query Database",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"How many active vacations are there?\"\n}"
            },
            "url": "{{baseUrl}}/api/mcp/query"
          }
        }
      ]
    },
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/health"
      }
    }
  ]
}
